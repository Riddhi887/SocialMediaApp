{
  "name": "twitter_client",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "node scripts/prepare-dev.cjs",
    "dev": "concurrently --kill-others-on-fail \"npm run server\" \"npm run codegen:watch\" \"npm run dev:next\"",
    "dev:next": "next dev -p 3000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "server": "npm --prefix ../twitter_server start",
    "codegen": "graphql-codegen --config codegen.ts",
    "codegen:watch": "graphql-codegen --config codegen.ts --watch"
  },
  "dependencies": {
    "@lobehub/icons": "^4.12.0",
    "@react-oauth/google": "^0.13.4",
    "@tailwindcss/vite": "^4.2.0",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.91.3",
    "graphql": "^16.13.1",
    "graphql-request": "^7.4.0",
    "next": "^16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^5.6.0"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "6.1.2",
    "@graphql-codegen/client-preset": "5.2.3",
    "@graphql-codegen/introspection": "5.0.0",
    "@parcel/watcher": "^2.5.6",
    "@tailwindcss/postcss": "^4.2.0",
    "@types/estree-jsx": "^1.0.5",
    "@types/hast": "^3.0.4",
    "@types/js-cookie": "^3.0.6",
    "@types/mdx": "^2.0.13",
    "@types/node": "^20",
    "@types/parse-json": "^4.0.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/unist": "^3.0.3",
    "autoprefixer": "^10.4.24",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.1",
    "typescript": "^5"
  }
}
